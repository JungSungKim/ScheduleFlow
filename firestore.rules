rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 사용자 개인 데이터 — 본인만 읽기/쓰기
    match /users/{uid}/sf-data/{doc} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // 캘린더 피드 — 누구나 읽기 가능, 쓰기는 로그인 필요
    // 보안: token(UUID)을 아는 사람만 URL을 알 수 있음
    match /publicCalendars/{token} {
      allow read: if true;
      allow write, delete: if request.auth != null;
    }
  }
}
